# API
API_BASE_URL=https://api.example.com/v1
API_CONNECT_TIMEOUT_MS=15000
API_RECEIVE_TIMEOUT_MS=15000

# OAuth
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
APPLE_SERVICE_ID=com.example.loginsystem.service

# Deep links
DEEP_LINK_SCHEME=loginsystem
DEEP_LINK_HOST=auth

# Token lifetimes (informational — enforced server-side)
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7
